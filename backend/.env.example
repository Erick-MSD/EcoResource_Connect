# ================================================
# ECORESOURCE CONNECT - ENVIRONMENT VARIABLES
# ================================================
# Copia este archivo a .env y configura tus valores
# Usa: node scripts/generateSecrets.js para generar automáticamente
# ================================================

# ================================================
# SERVER CONFIGURATION
# ================================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ================================================
# MONGODB ATLAS CONFIGURATION
# ================================================
# Obtén tu connection string de: https://cloud.mongodb.com/
# ⚠️ Añade el nombre de la base de datos antes del ?
# ⚠️ Codifica caracteres especiales: ! → %21, @ → %40, : → %3A
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# URI de prueba (mongomem simula esto en tests, este valor no se usa)
MONGODB_TEST_URI=mongodb://localhost:27017/ecoresource_connect_test

# ================================================
# JWT CONFIGURATION
# ================================================
# Genera con: node scripts/generateSecrets.js
# O manualmente: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_recommended_64_hex
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_different_from_above
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ================================================
# SECURITY CONFIGURATION
# ================================================
# Bcrypt rounds (12 = ~250ms, 10 = ~100ms, 14 = ~1s)
BCRYPT_ROUNDS=12

# Login attempts (lockout después de N intentos)
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=2h

# ================================================
# CORS CONFIGURATION
# ================================================
# Desarrollo local
CORS_ORIGIN=http://localhost:3000
# Producción: https://tu-app.web.app o tu dominio

# ================================================
# RATE LIMITING
# ================================================
# Ventana de tiempo (15 min = 900000ms)
RATE_LIMIT_WINDOW_MS=900000
# Máximo de requests por IP en la ventana
RATE_LIMIT_MAX_REQUESTS=100

# ================================================
# GEOSPATIAL CONFIGURATION
# ================================================
# Radio por defecto de búsqueda de donaciones (km)
DEFAULT_DONATION_RADIUS_KM=10
# Radio máximo permitido
MAX_DONATION_RADIUS_KM=50

# ================================================
# GOOGLE CLOUD PLATFORM (Producción)
# ================================================
# Para Cloud Run, estos se configuran en Google Secret Manager
# No necesitas definirlos aquí para desarrollo local
# GCP_PROJECT_ID=ecoresource-connect-2026
# GCP_REGION=us-central1
# GCP_SERVICE_NAME=ecoresource-backend

# ================================================
# LOGGING
# ================================================
# Nivel de logs: error, warn, info, debug, verbose
LOG_LEVEL=info
