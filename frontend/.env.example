# =========================================
# FRONTEND - VARIABLES DE ENTORNO
# =========================================
# Copiar este archivo a .env.local y configurar valores

# =========================================
# API BACKEND
# =========================================
# URL del backend API
# Desarrollo local: http://localhost:5000
# Producción GCP: https://ecoresource-backend-1028586104605.us-central1.run.app
VITE_API_URL=http://localhost:5000

# =========================================
# APLICACIÓN
# =========================================
# Nombre de la aplicación
VITE_APP_NAME=EcoResource Connect

# Entorno (development, staging, production)
VITE_APP_ENV=development

# =========================================
# GITHUB PAGES
# =========================================
# Base path para GitHub Pages
# Usa '/' si tienes dominio personalizado
# Usa '/EcoResource_Connect/' si usas username.github.io/EcoResource_Connect
VITE_BASE_PATH=/

# =========================================
# FEATURES
# =========================================
# Habilitar analytics (Google Analytics, etc.)
VITE_ENABLE_ANALYTICS=false

# Habilitar modo debug
VITE_DEBUG=false

# =========================================
# MAPAS
# =========================================
# OpenStreetMap es gratis, no necesita API key
# Si usas Google Maps o Mapbox, añade tu API key aquí
# VITE_MAPBOX_TOKEN=tu_token_aqui
# VITE_GOOGLE_MAPS_KEY=tu_key_aqui

# =========================================
# NOTIFICACIONES
# =========================================
# Para notificaciones push (opcional)
# VITE_FIREBASE_API_KEY=tu_key_aqui
# VITE_FIREBASE_PROJECT_ID=tu_proyecto
